{
  "name": "@guildpass/discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:shard": "node dist/shard.js",
    "dev": "tsx src/index.ts",
    "dev:shard": "tsx src/shard.ts",
    "register:commands": "tsx scripts/register-commands.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@guildpass/integration-client": "file:../../packages/integration-client",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "license": "MIT",
  "description": "GuildPass MVP Discord bot"
}
